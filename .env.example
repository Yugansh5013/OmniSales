# ============================================================
# OmniSales — Environment Variables
# Copy to .env and fill in your keys
# ============================================================

# --- LLM (Groq) ---
# Comma-separated for key rotation pool
GROQ_API_KEYS=gsk_YOUR_KEY_1,gsk_YOUR_KEY_2

# --- Database (Neon Cloud PostgreSQL) ---
DATABASE_URL=postgresql://neondb_owner:<your_password>@ep-<your-endpoint>.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
NEON_PROJECT_ID=small-lake-37805230
NEON_BRANCH_ID=br-frosty-cherry-a15xoyq0

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Kafka ---
KAFKA_BROKERS=kafka:9092

# --- Pinecone (RAG) ---
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=omnisales-knowledge

# --- OpenAI Embeddings (for Pinecone) ---
OPENAI_API_KEY=your_openai_api_key

# --- LangSmith Observability (optional) ---
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=omnisales

# --- Multi-tenant ---
ORG_ID=org_default

# --- MCP Server URLs ---
MCP_APPROVALS_URL=http://mcp-approvals:8004/mcp
MCP_KNOWLEDGE_URL=http://mcp-knowledge:8003/mcp
MCP_CRM_URL=http://mcp-crm:8001/mcp

# --- A2A ---
SPY_A2A_URL=http://spy-a2a:8080

# --- JWT Auth ---
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440
